# Pattern Scanner 环境变量配置示例
# 复制为 .env 并填写实际值

# ── 数据库 ──────────────────────────────────────────────────────────────────
# 开发：SQLite（默认）
PATTERN_SCANNER_DB_URL=sqlite+aiosqlite:///./pattern_scanner.db

# 生产：PostgreSQL
# PATTERN_SCANNER_DB_URL=postgresql+asyncpg://user:password@localhost:5432/pattern_scanner

# ── LLM（DeepSeek）───────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxx

# LLM 接口地址（默认 DeepSeek；改为 https://api.anthropic.com 可切回 Claude）
LLM_BASE_URL=https://api.deepseek.com

# 使用的模型
LLM_MODEL=deepseek-chat

# 是否启用 LLM（false 则只运行规则引擎）
PATTERN_SCANNER_RUN_LLM=true

# ── 扫描参数 ─────────────────────────────────────────────────────────────
# K线时间框架
PATTERN_SCANNER_TIMEFRAME=4h

# 每个 symbol 拉取的 K线数量
PATTERN_SCANNER_KLINE_BARS=500

# ── Web 服务器 ────────────────────────────────────────────────────────────
# 前端仪表盘端口（默认 8082）
# WEB_PORT=8082

# ── 代理（可选）──────────────────────────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ── 日志级别 ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
