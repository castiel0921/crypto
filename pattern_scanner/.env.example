# Pattern Scanner 环境变量配置示例
# 复制为 .env 并填写实际值

# ── 数据库 ──────────────────────────────────────────────────────────────────
# 开发：SQLite（默认）
PATTERN_SCANNER_DB_URL=sqlite+aiosqlite:///./pattern_scanner.db

# 生产：PostgreSQL
# PATTERN_SCANNER_DB_URL=postgresql+asyncpg://user:password@localhost:5432/pattern_scanner

# ── LLM（Anthropic Claude）────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 使用的模型（默认 Haiku 以节省成本）
PATTERN_SCANNER_LLM_MODEL=claude-haiku-4-5-20251001

# 是否启用 LLM（false 则只运行规则引擎）
PATTERN_SCANNER_RUN_LLM=true

# ── 扫描参数 ─────────────────────────────────────────────────────────────
# K线时间框架
PATTERN_SCANNER_TIMEFRAME=4h

# 每个 symbol 拉取的 K线数量
PATTERN_SCANNER_KLINE_BARS=500

# ── 代理（可选）──────────────────────────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ── 日志级别 ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
