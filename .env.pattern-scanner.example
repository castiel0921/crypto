# Pattern Scanner Docker 环境变量
# 复制为 .env.pattern-scanner 并填写实际值：
#   cp .env.pattern-scanner.example .env.pattern-scanner

# ── 必填 ──────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxx

# ── 可选（以下均有默认值）────────────────────────────────────────────────────

# LLM 接口（默认 DeepSeek）
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 扫描周期（逗号分隔）
PATTERN_SCANNER_TIMEFRAMES=4h,1h,15m

# 日志级别
LOG_LEVEL=INFO

# 注意：PATTERN_SCANNER_DB_URL 已由 docker-compose.yml 自动设置，无需填写
