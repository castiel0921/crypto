[Unit]
Description=Crypto Binance REST Poller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/projects/crypto
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/projects/crypto/.venv/bin/python /home/ubuntu/projects/crypto/scripts/binance_rest_poll.py --symbol BTC/USDT --kind ticker --interval 2 --max-polls 0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
